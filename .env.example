# ============================================================================
# Legal AI OS — Saudi Edition  /  environment template
# Copy this file to `.env` and fill in real values for local development.
# Never commit the populated `.env`.
# ============================================================================

# --- Core ---
APP_ENV=development
APP_NAME="Legal AI OS"
APP_BASE_URL=http://localhost:3030
API_BASE_URL=http://localhost:8000

# Wildcard root for tenant subdomains. Each tenant is reachable at
# `<their-subdomain>.<BASE_DOMAIN>`. Leave empty in local dev — the API
# then skips subdomain resolution. In production set this to your
# registered domain (e.g. `legalai.sa`) and configure wildcard DNS
# (`A *.legalai.sa → load balancer`) plus a wildcard TLS cert.
BASE_DOMAIN=
ENABLE_SUBDOMAIN_CORS=true

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=14

# Single-use auth token TTLs.
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30
INVITE_TTL_DAYS=7

# Login lockout (Redis-backed; soft-fails open if Redis is down).
LOGIN_LOCKOUT_MAX_ATTEMPTS=8
LOGIN_LOCKOUT_WINDOW_SECONDS=900

# --- Email ---
# `console` logs the email body to stdout (useful for dev — copy verification
# links from the log). `smtp` sends through the SMTP server below.
EMAIL_BACKEND=console
EMAIL_FROM="Legal AI OS <noreply@example.com>"
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=true
EMAIL_SMTP_USE_SSL=false

# --- Database (Postgres + pgvector) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legalai
POSTGRES_USER=legalai
POSTGRES_PASSWORD=legalai
DATABASE_URL=postgresql+psycopg://legalai:legalai@localhost:5432/legalai

# --- Redis (cache + Celery broker) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Object storage (S3 compatible — MinIO locally) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=legalai-documents
S3_FORCE_PATH_STYLE=true

# --- LLM provider (configurable) ---
# Supported: openai | anthropic | azure-openai | chatgpt-oauth
# `chatgpt-oauth` uses the Codex backend with a ChatGPT Plus session JWT —
# no platform API key required. See OPENAI_CHATGPT_TOKEN below.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-...
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# --- ChatGPT OAuth (Codex backend) ---
# The dashboard agent + WhatsApp agent (tool use) always go through this,
# regardless of LLM_PROVIDER above. Grab the token from chatgpt.com DevTools
# (Application → Cookies, or any /backend-api/* request's Authorization
# header) — it's a JWT starting with "eyJ...". Expires ~7 days.
OPENAI_CHATGPT_TOKEN=
OPENAI_CHATGPT_MODEL=gpt-5.2
OPENAI_CHATGPT_EFFORT=low
OPENAI_CHATGPT_TIMEOUT_S=120

# --- Embeddings ---
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-large
EMBEDDINGS_DIM=3072

# --- Billing: Stripe (international) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# --- Billing: Moyasar (Saudi Arabia) ---
MOYASAR_PUBLISHABLE_KEY=pk_test_...
MOYASAR_SECRET_KEY=sk_test_...
MOYASAR_WEBHOOK_SECRET=whsec_...

# --- WhatsApp (Twilio — optional Business API path) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- WhatsApp (Baileys bridge — QR pairing) ---
# The Node service in apps/whatsapp-bridge holds Baileys sockets per tenant.
# Generate a long random string and use the same value on both sides.
WHATSAPP_BRIDGE_URL=http://localhost:8787
WHATSAPP_BRIDGE_SECRET=change-me-to-a-long-random-string
WHATSAPP_BRIDGE_TIMEOUT_S=30

# --- Observability ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
LOG_LEVEL=INFO

# --- Lifecycle / compliance ---
# PDPL grace windows. Tenants/users can undo deletion until purge_at fires.
ACCOUNT_DELETION_GRACE_DAYS=14
TENANT_DELETION_GRACE_DAYS=30

# Trial + dunning windows (run by the Celery beat lifecycle sweep).
TRIAL_DEFAULT_LENGTH_DAYS=14
DUNNING_FIRST_REMINDER_DAYS=3
DUNNING_SECOND_REMINDER_DAYS=7
DUNNING_SUSPEND_AFTER_DAYS=14

# --- VAT / ZATCA invoicing ---
VAT_RATE=0.15
VAT_SELLER_NAME="Legal AI OS"
VAT_SELLER_VAT_NUMBER=
VAT_SELLER_ADDRESS_AR=المملكة العربية السعودية
VAT_SELLER_ADDRESS_EN="Kingdom of Saudi Arabia"

# --- Feature flags ---
ENABLE_WHATSAPP=true
ENABLE_WHATSAPP_BAILEYS=true
ENABLE_MOYASAR=true
# When true (default), only tenants with an active subscription can pair a
# WhatsApp number through the dashboard. Set to false for local dev.
REQUIRE_SUBSCRIPTION_FOR_WHATSAPP=true
