# Port the bridge listens on. FastAPI must be configured with
# WHATSAPP_BRIDGE_URL=http://<host>:<this port>
PORT=8787

# Shared secret. Must match WHATSAPP_BRIDGE_SECRET in the FastAPI .env.
# Sent on every request in both directions in the X-Bridge-Secret header.
BRIDGE_SECRET=change-me-to-a-long-random-string

# Where the bridge POSTs inbound messages + session updates.
API_BASE_URL=http://localhost:8000

# Where Baileys auth files live, one subfolder per tenant. Don't delete the
# subfolder for a connected tenant — they'll need to scan the QR again.
AUTH_DIR=./baileys_auth

# Re-issue the QR string at this interval while pairing (Baileys re-emits
# QRs every ~20s; we cache the latest in memory).
QR_REFRESH_MS=20000
