# Copy to apps/api/.env and fill in. Never commit the real .env.
APP_ENV=development
APP_BASE_URL=http://localhost:3030
API_BASE_URL=http://localhost:8000

JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=14

# Postgres (pgvector image). In Docker/Podman compose this is host 5433.
DATABASE_URL=postgresql+psycopg://legalai:legalai@localhost:5433/legalai
REDIS_URL=redis://localhost:6379/0

# S3 / MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=legalai-documents
S3_FORCE_PATH_STYLE=true

# LLM provider: chatgpt-oauth (Codex / gpt-5.5) or gemini (Code Assist).
LLM_PROVIDER=chatgpt-oauth
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=intfloat/multilingual-e5-small
EMBEDDINGS_DIM=384

AGENT_PROVIDER=chatgpt-oauth
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_S=180

# ChatGPT Codex OAuth — produced by scripts/codex_oauth_manual.py.
# The token + refresh_token live in apps/api/.codex_oauth.json (gitignored);
# this var is the static fallback. Headless auto-login creds (optional):
OPENAI_AUTH_EMAIL=
OPENAI_AUTH_PASSWORD=
OPENAI_CHATGPT_TOKEN=
OPENAI_CHATGPT_MODEL=gpt-5.5
OPENAI_CHATGPT_EFFORT=low
OPENAI_CHATGPT_TIMEOUT_S=180
OPENAI_CODEX_CREDS_PATH=.codex_oauth.json

ENABLE_WHATSAPP=true
ENABLE_WHATSAPP_BAILEYS=true
ENABLE_MOYASAR=false
REQUIRE_SUBSCRIPTION_FOR_WHATSAPP=false
WHATSAPP_BRIDGE_URL=http://localhost:8787
WHATSAPP_BRIDGE_SECRET=change-me-to-a-long-random-string

USE_PGVECTOR=true
LOG_LEVEL=INFO
